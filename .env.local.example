# .env.local : Hibou ESG
# Copy this to .env.local and fill in your values.
# Never commit .env.local to version control.

# Supabase : get from https://supabase.com/dashboard/project/<id>/settings/api
# Use Publishable for NEXT_PUBLIC_SUPABASE_ANON_KEY and Secret for SUPABASE_KEY.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key-here
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Used by Python ingestion scripts and LLM calls (server-side only)
# This is the Secret key (service role).
SUPABASE_KEY=your-secret-key-here
# LLM provider: anthropic | ollama
LLM_PROVIDER=anthropic

# Anthropic (optional if using Ollama; required for ingestion/generate_narratives.py)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Ollama (optional if using Anthropic)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=180

# Optional admin secret for server-to-server AI requests (/api/narrative, /api/context).
# Generate with: openssl rand -hex 32
# If set, send it in the X-Hibou-Admin header from trusted servers only.
HIBOU_API_SECRET=change-me-generate-with-openssl-rand-hex-32

# Optional : used by `npm run db:types` to regenerate TypeScript types
SUPABASE_PROJECT_ID=your-project-id

# Sentry (error monitoring) : optional, requires @sentry/nextjs
# Create a project in Sentry and copy the DSN.
# NEXT_PUBLIC_SENTRY_DSN=your-public-dsn-here
# SENTRY_DSN=your-server-dsn-here
# Optional for source maps (set in CI only)
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=hibou
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Upstash (optional rate limiting)
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
